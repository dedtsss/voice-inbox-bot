# Telegram
TELEGRAM_BOT_TOKEN=123456:REPLACE_ME
ALLOWED_TELEGRAM_USER_IDS=123456789

# OpenAI API
OPENAI_API_KEY=sk-REPLACE_ME
OPENAI_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe
OPENAI_STRUCTURING_MODEL=gpt-4o-mini

# Airtable API Personal Access Token
# Scopes: data.records:read, data.records:write for the required bases.
AIRTABLE_TOKEN=pat_REPLACE_ME

# Airtable: Voice Inbox base/table
# Use private values from deployment configuration. Do not commit real IDs.
VOICE_INBOX_BASE_ID=app_REPLACE_ME
VOICE_INBOX_TABLE_ID=tbl_REPLACE_ME

# Voice Inbox fields. Field names are valid defaults; production may use private field IDs in .env.
VOICE_FIELD_TITLE=Название
VOICE_FIELD_TYPE=Тип
VOICE_FIELD_PROJECT=Проект
VOICE_FIELD_PRIORITY=Приоритет
VOICE_FIELD_DUE_DATE=Срок
VOICE_FIELD_COUNTERPARTY=Контрагент
VOICE_FIELD_AMOUNT=Сумма
VOICE_FIELD_PERIOD=Период
VOICE_FIELD_NEXT_ACTION=Следующее действие
VOICE_FIELD_SUMMARY=Краткое содержание
VOICE_FIELD_CLEAN_TEXT=Очищенный текст
VOICE_FIELD_RAW_TEXT=Исходная фраза
VOICE_FIELD_TAGS=Теги
VOICE_FIELD_PROCESSING_STATUS=Статус обработки
VOICE_FIELD_PROCESSING_STATUS_QUERY_NAME=Статус обработки
VOICE_FIELD_ATTACHMENTS=Attachments
VOICE_FIELD_NOTES=Notes
VOICE_FIELD_EXTERNAL_ID=External ID
VOICE_FIELD_EXTERNAL_ID_QUERY_NAME=External ID
VOICE_FIELD_GOOGLE_DRIVE=Google Drive
VOICE_FIELD_SOURCE=Источник
VOICE_FIELD_SOURCE_QUERY_NAME=Источник
VOICE_FIELD_PROCESSING_ERROR=Ошибка обработки
VOICE_FIELD_AI_RESULT_JSON=AI результат JSON
VOICE_FIELD_AI_CONFIDENCE=Уверенность AI
VOICE_FIELD_PROCESSOR_VERSION=Версия обработчика
VOICE_FIELD_TRAIN_ON_CORRECTION=Обучить на исправлении
VOICE_FIELD_CORRECTION_COMMENT=Комментарий к исправлению
VOICE_FIELD_TRAINING_APPLIED=Обучение учтено

# Airtable: Projects OS base/table/fields
# Replace with private IDs or exact field names used by the target bases.
PROJECTS_BASE_ID=app_REPLACE_ME
PROJECTS_TABLE_ID=tbl_REPLACE_ME
PROJECTS_FIELD_TITLE=REPLACE_WITH_PROJECT_TITLE_FIELD
ITEMS_TABLE_ID=tbl_REPLACE_ME
ITEMS_FIELD_TITLE=REPLACE_WITH_ITEM_TITLE_FIELD
ITEMS_FIELD_PROJECT=REPLACE_WITH_ITEM_PROJECT_FIELD
ITEMS_FIELD_TYPE=REPLACE_WITH_ITEM_TYPE_FIELD
ITEMS_FIELD_STATUS=REPLACE_WITH_ITEM_STATUS_FIELD
ITEMS_FIELD_PRIORITY=REPLACE_WITH_ITEM_PRIORITY_FIELD
ITEMS_FIELD_TEXT=REPLACE_WITH_ITEM_TEXT_FIELD
ITEMS_FIELD_NEXT_ACTION=REPLACE_WITH_ITEM_NEXT_ACTION_FIELD
ITEMS_FIELD_SOURCE=REPLACE_WITH_ITEM_SOURCE_FIELD
ITEMS_FIELD_DATE=REPLACE_WITH_ITEM_DATE_FIELD
ITEMS_FIELD_BLOCK=
ITEMS_FIELD_STAGE=

# Optional behavior
WRITE_TO_PROJECTS_OS=true
SAVE_MEDIA_FILES=true
DATA_DIR=/app/data
TIMEZONE=Europe/Moscow

# HTTP API
HTTP_HOST=0.0.0.0
HTTP_PORT=8080
HTTP_PUBLISHED_PORT=8080

# Android mobile inbox
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
MOBILE_INBOX_TOKEN=
ANDROID_RAW_MODE=true
MOBILE_INBOX_MAX_FILE_BYTES=5000000
MOBILE_INBOX_MAX_FILES=5
MOBILE_INBOX_MAX_REQUEST_BYTES=25000000
MOBILE_INBOX_MAX_PAYLOAD_BYTES=65536
MOBILE_INBOX_ALLOWED_MIME_TYPES=audio/aac,audio/mp3,audio/mp4,audio/mpeg,audio/ogg,audio/opus,audio/wav,audio/webm,audio/x-m4a,image/heic,image/heif,image/jpeg,image/png,image/webp,video/mp4,video/quicktime,video/webm,application/json,application/pdf,text/plain
AIRTABLE_UPLOAD_BASE_URL=https://content.airtable.com/v0
AIRTABLE_AUTO_ENSURE_FIELDS=false

# Google Drive original file storage
GOOGLE_DRIVE_ENABLED=false
GOOGLE_DRIVE_ROOT_FOLDER_ID=REPLACE_WITH_PRIVATE_FOLDER_ID
GOOGLE_DRIVE_CREDENTIALS_FILE=/app/data/secrets/google-drive-client.json
GOOGLE_DRIVE_TOKEN_FILE=/app/data/secrets/google-drive-token.json
GOOGLE_DRIVE_SPOOL_DIR=/app/data/google_drive_spool

# Multimodal Android raw processor. Keep disabled for first deploy.
VOICE_PROCESSOR_ENABLED=false
VOICE_PROCESSOR_INTERVAL_SECONDS=60
VOICE_PROCESSOR_BATCH_SIZE=5
VOICE_PROCESSOR_TEXT_MODEL=gpt-4o-mini
VOICE_PROCESSOR_TRANSCRIPTION_MODEL=gpt-4o-transcribe
VOICE_PROCESSOR_CONFIDENCE_THRESHOLD=0.80
VOICE_PROCESSOR_MAX_VIDEO_FRAMES=12
VOICE_PROCESSOR_VIDEO_FRAME_INTERVAL_SECONDS=5
VOICE_PROCESSOR_CREATE_PROJECT_ITEMS=false
VOICE_PROCESSOR_SOURCE_FILTER=Android
VOICE_PROCESSOR_CREATED_AFTER=
VOICE_PROCESSOR_VERSION=v1
VOICE_PROCESSOR_STALE_PROCESSING_SECONDS=900
VOICE_PROCESSOR_MAX_RETRIES=3
VOICE_PROCESSOR_RETRY_BASE_SECONDS=1
VOICE_PROCESSOR_MAX_PROMPT_CHARS=24000
VOICE_PROCESSOR_MAX_RULES=8
VOICE_PROCESSOR_MAX_FILE_BYTES=25000000
VOICE_PROCESSOR_MAX_RECORD_BYTES=50000000
VOICE_PROCESSOR_MAX_IMAGE_BYTES=4000000
VOICE_PROCESSOR_IMAGE_MAX_EDGE=1600
VOICE_PROCESSOR_RULES_TABLE_ID=
VOICE_PROCESSOR_RULES_TABLE_NAME=Правила обработки
